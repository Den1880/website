<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Den 1880 for Teams</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
@font-face {
  font-family: 'Monschone';
  src: url('../assets/fonts/Monschone.ttf') format('truetype');
  font-weight: normal;
  font-style: normal;
}

  :root{
    --ink:#0E0E0E;
    --ink-2:#2A2A2A;
    --paper:#F7F4EE;
    --card:#FFFFFF;
    --line:#E6E1D6;
    --muted:#6F6A60;
    --lime:#C8E020;
    --lime-deep:#9DB315;
    --plum:#6B4E8E;
    --gold:#B89252;
    --warn:#C0392B;
    --shadow:0 1px 2px rgba(14,14,14,.04), 0 8px 32px rgba(14,14,14,.06);
    --shadow-lift:0 2px 6px rgba(14,14,14,.06), 0 24px 60px rgba(14,14,14,.12);
    --radius:14px;
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  html,body{margin:0;padding:0;background:var(--paper);color:var(--ink);font-family:'Inter',system-ui,-apple-system,sans-serif;font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased}
  h1,h2,h3,h4{font-family:'Monschone',Georgia,serif;font-weight:600;letter-spacing:-0.01em;margin:0}
  h1{font-size:clamp(40px,6vw,72px);line-height:1.02;letter-spacing:-0.025em}
  h2{font-size:clamp(28px,3.4vw,42px);line-height:1.1}
  h3{font-size:clamp(20px,2vw,26px)}
  p{margin:0 0 .8em}
  a{color:inherit}
  .container{max-width:1280px;margin:0 auto;padding:0 24px}

  .topbar{display:flex;justify-content:space-between;align-items:center;padding:18px 24px;border-bottom:1px solid var(--line);background:var(--paper);position:sticky;top:0;z-index:50;backdrop-filter:blur(8px)}
  .logo{display:inline-flex;align-items:center}
  .nav-cta{display:flex;gap:10px;align-items:center}
  .btn{display:inline-flex;align-items:center;gap:8px;padding:12px 20px;border-radius:999px;font-weight:600;font-size:14px;text-decoration:none;border:1px solid transparent;transition:transform .15s ease, background .15s ease, box-shadow .15s ease;cursor:pointer}
  .btn-primary{background:var(--ink);color:#fff}
  .btn-primary:hover{background:var(--plum);transform:translateY(-1px)}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--ink)}
  .btn-ghost:hover{background:var(--ink);color:#fff}
  .btn-lime{background:var(--lime);color:var(--ink)}
  .btn-lime:hover{background:var(--lime-deep)}
  .btn-sm{padding:9px 16px;font-size:13px}

  .hero{padding:72px 0 36px;text-align:center;position:relative;overflow:hidden}
  .hero .eyebrow{display:inline-block;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:18px}
  .hero h1 em{font-style:italic;color:var(--plum)}
  .hero p.lede{max-width:760px;margin:18px auto 0;color:var(--ink-2);font-size:18px}
  .hero-fineprint{margin-top:28px;color:var(--muted);font-size:13px}
  .hero-fineprint strong{color:var(--ink);font-weight:600}

  /* PATH SELECTOR (3-card team-shape chooser) */
  .path-selector{max-width:1080px;margin:0 auto}
  .path-eyebrow{display:block;text-align:center;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:8px}
  .path-selector h2{text-align:center;font-size:clamp(24px,3.2vw,34px);margin-bottom:24px}
  .path-options{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-top:8px}
  @media (max-width:900px){.path-options{grid-template-columns:1fr;max-width:520px;margin-left:auto;margin-right:auto}}
  .path-card{display:flex;flex-direction:column;background:#fff;border:1.5px solid var(--line);border-radius:14px;padding:22px 22px 20px;text-decoration:none;color:var(--ink);transition:all .18s ease;cursor:pointer;position:relative}
  .path-card:hover{border-color:var(--lime-deep);box-shadow:0 10px 28px rgba(157,179,21,.18);transform:translateY(-2px)}
  .path-card .path-num{display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:50%;background:var(--lime);color:var(--ink);font-family:'Fraunces';font-weight:800;font-size:14px;margin-bottom:14px;border:2px solid var(--ink)}
  .path-card h3{font-family:'Fraunces';font-weight:600;font-size:18px;line-height:1.25;margin-bottom:8px}
  .path-card p{font-size:13px;color:var(--ink-2);line-height:1.5;margin:0 0 14px;flex:1}
  .path-card .path-cta{font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--lime-deep);margin-top:auto}
  .path-card .path-cta::after{content:' →';font-weight:700}
  .path-card:hover .path-cta{color:var(--ink)}

  /* DROP-IN single banner */
  .dropin-banner{max-width:980px;margin:0 auto;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:28px 32px;display:grid;grid-template-columns:1fr auto;gap:32px;align-items:center;box-shadow:var(--shadow)}
  @media (max-width:680px){.dropin-banner{grid-template-columns:1fr;text-align:center}}
  .dropin-eyebrow{display:inline-block;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px}
  .dropin-banner h3{font-family:'Fraunces';font-weight:600;font-size:24px;margin-bottom:8px}
  .dropin-banner p{margin:0;color:var(--ink-2);font-size:14px;line-height:1.55}
  .dropin-price{text-align:right}
  @media (max-width:680px){.dropin-price{text-align:center}}
  .dropin-price .num{font-family:'Fraunces';font-weight:800;font-size:48px;line-height:1;letter-spacing:-.02em;color:var(--ink)}
  .dropin-price .unit{font-size:13px;color:var(--muted);margin-bottom:14px;display:block;margin-top:4px}

  /* MONTHLY / ANNUAL toggle */
  .toggle-wrap{display:flex;justify-content:center;align-items:center;gap:16px;margin:36px 0 8px}
  .toggle{display:inline-flex;background:#fff;border:1px solid var(--line);border-radius:999px;padding:4px;box-shadow:var(--shadow);position:relative}
  .toggle button{border:0;background:transparent;font-family:inherit;font-size:14px;font-weight:600;padding:10px 20px;border-radius:999px;cursor:pointer;color:var(--muted);transition:all .2s ease}
  .toggle button.active{background:var(--ink);color:#fff}
  .annual-pill{position:absolute;top:-28px;right:0;background:var(--lime);color:var(--ink);font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;padding:5px 11px;border-radius:999px;white-space:nowrap;box-shadow:0 3px 10px rgba(157,179,21,.4);border:1.5px solid var(--ink);animation:bobble 2.4s ease-in-out infinite;pointer-events:none}
  .annual-pill::after{content:'';position:absolute;bottom:-5px;right:28px;transform:rotate(45deg);width:8px;height:8px;background:var(--lime);border-right:1.5px solid var(--ink);border-bottom:1.5px solid var(--ink)}
  @keyframes bobble{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
  .plan .annual-note{display:none;font-size:11px;color:var(--plum);font-weight:600;letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px}
  .plan .annual-note.show{display:block}
  .plan .reg-price{font-size:13px;color:var(--muted);margin-bottom:2px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .plan .reg-price s{color:#B5AFA1;font-variant-numeric:tabular-nums}
  .plan .reg-price .limited{display:inline-block;background:var(--warn);color:#fff;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase}

  /* VALUE STACK callout per card */
  .plan .value-stack{margin:14px 0 12px;padding:14px 16px;background:linear-gradient(135deg,rgba(200,224,32,0.14) 0%,rgba(157,179,21,0.08) 100%);border:1.5px solid var(--lime-deep);border-radius:12px}
  .plan .vs-label{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--lime-deep);font-weight:800;margin-bottom:8px;text-align:center}
  .plan .vs-row{display:flex;justify-content:space-between;align-items:baseline;font-size:12px;color:var(--ink-2);padding:3px 0;gap:8px}
  .plan .vs-row .vs-val{color:var(--ink);font-weight:600;font-variant-numeric:tabular-nums;white-space:nowrap}
  .plan .vs-row.vs-total{font-family:'Fraunces';font-weight:700;color:var(--ink);font-size:14px;border-top:1px dashed var(--lime-deep);margin-top:6px;padding-top:8px}
  .plan .vs-row.vs-total .vs-val{font-size:15px;color:var(--ink)}
  .plan .vs-row.vs-cost{color:var(--muted);font-size:12px;padding-top:4px}
  .plan .vs-row.vs-cost .vs-val{color:var(--muted)}
  .plan .vs-save{text-align:center;margin-top:8px;padding:8px 0;background:var(--lime);border-radius:8px;font-family:'Fraunces';font-weight:800;color:var(--ink);font-size:14px;border:1.5px solid var(--ink)}
  .plan .vs-save .vs-pct{font-size:12px;font-weight:700;margin-left:4px;color:var(--ink)}

  /* plan card secondary "Try for free" CTA (Box-style: outlined link button below primary CTA) */
  .plan .cta-stack{display:flex;flex-direction:column;gap:8px;margin-top:auto}
  .plan .try-free{display:flex;align-items:center;justify-content:center;gap:8px;padding:12px 16px;border:1.5px dashed var(--lime-deep);border-radius:12px;background:rgba(200,224,32,0.08);color:var(--ink);font-weight:700;font-size:13px;text-decoration:none;transition:all .15s ease}
  .plan .try-free:hover{background:var(--lime);border-style:solid;transform:translateY(-1px)}
  .plan .try-free .tf-icon{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:var(--lime);color:var(--ink);font-size:11px;font-weight:800;flex-shrink:0}
  .plan .try-free .tf-arrow{margin-left:2px}
  .plan.featured .try-free{background:#fff;border-color:var(--ink)}
  .plan.featured .try-free:hover{background:var(--lime);border-color:var(--ink)}

  /* MEMBERSHIPS, container around the 3-card plans grid */
  .memberships{max-width:1200px;margin:24px auto 0;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:36px 32px 32px;box-shadow:var(--shadow)}
  .mb-header{text-align:center;margin-bottom:28px}
  .mb-header .mb-eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;display:inline-block}
  .mb-header h2{font-size:clamp(28px,3.4vw,38px);margin-bottom:8px;line-height:1.1}
  .mb-header p{font-size:14px;color:var(--ink-2);margin:0 auto;max-width:680px}
  .memberships .plans{padding-top:32px}

  /* PLAN GRID, 3 tier */
  .plans{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin:24px auto 12px;align-items:stretch;max-width:1080px}
  @media (max-width:900px){.plans{grid-template-columns:1fr;max-width:480px}}
  .plan{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:28px 22px 24px;display:flex;flex-direction:column;position:relative;transition:transform .2s ease, box-shadow .2s ease;box-shadow:var(--shadow)}
  .plan:hover{transform:translateY(-3px);box-shadow:var(--shadow-lift)}
  .plan .ribbon{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--ink);color:var(--lime);font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;padding:7px 14px;border-radius:999px;white-space:nowrap}
  .plan.featured{border-color:var(--ink);box-shadow:0 6px 12px rgba(14,14,14,.06), 0 36px 80px rgba(107,78,142,.18);transform:translateY(-8px) scale(1.04);z-index:2;background:linear-gradient(180deg,#fff 0%,#FBF9F3 100%)}
  .plan.featured:hover{transform:translateY(-11px) scale(1.04)}
  .plan .ptitle{font-family:'Fraunces';font-weight:600;font-size:24px;letter-spacing:-.01em;margin-bottom:4px}
  .plan .ptag{font-size:13px;color:var(--muted);min-height:42px;margin-bottom:18px}
  .plan .price{display:flex;align-items:baseline;gap:6px;margin-bottom:6px}
  .plan .price .currency{font-size:18px;color:var(--muted);font-weight:500}
  .plan .price .amount{font-family:'Fraunces';font-weight:800;font-size:48px;line-height:1;letter-spacing:-.02em}
  .plan .price .unit{font-size:13px;color:var(--muted);font-weight:500}
  .plan .perworker{display:flex;align-items:baseline;gap:6px;margin:4px 0 6px;font-size:13px;color:var(--ink-2)}
  .plan .perworker .pwd{font-family:'Fraunces';font-weight:700;font-size:17px;color:var(--lime-deep);letter-spacing:-.01em}
  .plan .perworker .pwd-label{font-weight:500;color:var(--ink-2)}
  .plan.featured .perworker .pwd{color:var(--ink)}
  .plan .perday{display:inline-flex;align-items:baseline;gap:6px;background:rgba(200,224,32,.18);color:var(--ink);padding:6px 12px;border-radius:999px;font-size:13px;font-weight:600;margin:8px 0 6px;border:1px solid rgba(157,179,21,.35)}
  .plan .perday .perday-num{font-family:'Fraunces';font-size:16px;font-weight:700;color:var(--lime-deep)}
  .plan.featured .perday{background:var(--lime);border-color:var(--lime-deep)}
  .plan .price-sub{font-size:12px;color:var(--muted);margin-bottom:6px}
  .plan .anchor{font-size:12px;color:var(--muted);margin-bottom:16px}
  .plan .anchor strong{color:var(--lime-deep)}
  .plan ul{list-style:none;margin:14px 0 22px;padding:0;flex:1}
  .plan li{display:flex;gap:10px;padding:7px 0;font-size:14px;color:var(--ink-2);align-items:flex-start;line-height:1.4}
  .plan li svg{flex:0 0 16px;margin-top:3px}
  .plan li.disabled{color:#B0AB9F}
  .plan li.disabled svg{color:#D4CFC1}
  .plan li.hero-feature{font-weight:600;color:var(--ink)}
  .plan .cta{margin-top:auto}
  .plan .cta a{width:100%;justify-content:center}
  .plan .micro{margin-top:10px;font-size:11px;color:var(--muted);text-align:center}
  .plan .guarantee-badge{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px;padding:8px 10px;background:rgba(200,224,32,.14);border:1px dashed var(--lime-deep);border-radius:8px;font-size:11px;font-weight:600;color:var(--ink);letter-spacing:.02em;text-align:center}
  .plan .guarantee-badge svg{color:var(--lime-deep);flex-shrink:0}

  /* DAY PASS BUNDLES, mini section like the consumer chart */
  .daypass{max-width:980px;margin:56px auto 0;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:36px 32px 32px;box-shadow:var(--shadow)}
  .dp-header{text-align:center;margin-bottom:28px}
  .dp-header .dp-eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;display:inline-block}
  .dp-header h3{font-size:24px;margin-bottom:8px}
  .dp-header p{font-size:14px;color:var(--ink-2);margin:0 auto;max-width:640px}
  .dp-options{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;align-items:stretch;padding-top:8px}
  @media (max-width:760px){.dp-options{grid-template-columns:1fr;gap:14px}}
  .dp-option{border:1px solid var(--line);border-radius:10px;padding:20px 16px 18px;text-align:center;background:#FBF9F3;transition:all .2s ease;display:flex;flex-direction:column;position:relative}
  .dp-option:hover{border-color:var(--ink);background:#fff}
  .dp-option.featured{border:1.5px solid var(--ink);box-shadow:0 4px 8px rgba(14,14,14,.06), 0 18px 40px rgba(107,78,142,.16);transform:translateY(-8px) scale(1.04);z-index:2;background:linear-gradient(180deg,#fff 0%,#FBF9F3 100%);padding-top:26px}
  .dp-option.featured:hover{transform:translateY(-11px) scale(1.04)}
  .dp-ribbon{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--ink);color:var(--lime);font-size:9px;letter-spacing:.16em;text-transform:uppercase;font-weight:700;padding:5px 11px;border-radius:999px;white-space:nowrap}
  .dp-option .dp-label{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:10px}
  .dp-option .dp-price{font-family:'Fraunces';font-weight:700;font-size:30px;letter-spacing:-.02em;color:var(--ink);line-height:1;white-space:nowrap}
  .dp-option .dp-price small{font-size:12px;color:var(--muted);font-weight:500;font-family:'Inter'}
  .dp-option .dp-sub{font-size:12px;color:var(--muted);margin-top:6px;min-height:32px;flex:1}
  .dp-option .dp-cta{margin-top:14px}
  .dp-option .dp-cta a{display:flex;width:100%;justify-content:center}

  section{padding:72px 0}
  section h2{text-align:center;margin-bottom:8px}
  section .sub{text-align:center;color:var(--muted);max-width:680px;margin:0 auto 40px}

  .compare{background:#fff;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
  .compare table{width:100%;border-collapse:collapse;font-size:14px}
  .compare th, .compare td{padding:14px 16px;text-align:left;border-bottom:1px solid var(--line)}
  .compare th{background:#FBF9F3;font-weight:600;font-size:13px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);position:sticky;top:0}
  .compare th.col, .compare td.col{text-align:center}
  .compare th.col-feat{background:var(--ink);color:var(--lime);text-align:center;position:relative}
  .compare td.col-feat{background:#FCFBF7;text-align:center}
  .compare td.row-section{background:var(--paper);font-family:'Fraunces';font-weight:600;font-size:15px;letter-spacing:-.005em;color:var(--ink);text-transform:none}
  .compare svg.tick{color:var(--lime-deep)}
  .compare svg.dash{color:#D6D1C4}
  .compare .lite{color:var(--muted);font-size:13px}
  .compare tr:last-child td{border-bottom:0}

  .teams-band{background:var(--ink);color:#fff;border-radius:var(--radius);padding:48px 40px;display:grid;grid-template-columns:1.4fr 1fr;gap:40px;align-items:center;box-shadow:var(--shadow-lift)}
  @media (max-width:880px){.teams-band{grid-template-columns:1fr}}
  .teams-band h2{text-align:left;color:#fff}
  .teams-band .scarce{display:inline-block;background:rgba(200,224,32,.16);color:var(--lime);font-size:12px;letter-spacing:.12em;text-transform:uppercase;font-weight:700;padding:6px 12px;border-radius:6px;margin-bottom:18px}
  .teams-band p{color:#CDC8BC}
  .teams-band .team-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:24px}
  .teams-band .stat{background:rgba(255,255,255,.05);padding:18px;border-radius:10px}
  .teams-band .stat .num{font-family:'Fraunces';font-weight:600;font-size:22px;color:var(--lime)}
  .teams-band .stat .lbl{font-size:12px;color:#CDC8BC;letter-spacing:.04em;text-transform:uppercase;margin-top:6px}

  /* COMMUNITY MEMBERSHIP section, relationship tier for companies not ready for a Team plan */
  .community{max-width:980px;margin:56px auto 0;background:#fff;border:1px solid var(--line);border-radius:var(--radius);padding:36px 32px;box-shadow:var(--shadow);display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:center}
  @media (max-width:780px){.community{grid-template-columns:1fr;gap:24px}}
  .community .cm-eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:8px;display:inline-block}
  .community h3{font-size:24px;margin-bottom:10px}
  .community p.cm-pitch{font-size:14px;color:var(--ink-2);margin-bottom:14px;line-height:1.5}
  .community ul.cm-benefits{list-style:none;margin:14px 0 18px;padding:0;font-size:13px;color:var(--ink-2)}
  .community ul.cm-benefits li{padding:5px 0;display:flex;gap:8px;line-height:1.45;align-items:flex-start}
  .community ul.cm-benefits li svg{flex:0 0 14px;margin-top:3px;color:var(--lime-deep)}
  .community ul.cm-benefits li.cm-hero{background:var(--lime);border:1.5px solid var(--ink);border-radius:10px;padding:12px 14px;margin:8px 0 14px;font-size:13.5px;color:var(--ink);line-height:1.5;align-items:flex-start}
  .community ul.cm-benefits li.cm-hero svg{color:var(--ink);margin-top:5px}
  .community ul.cm-benefits li.cm-hero strong{color:var(--ink);font-weight:800}
  .cm-payback-seal{display:flex;gap:10px;align-items:center;background:var(--ink);color:#fff;border-radius:10px;padding:12px 16px;font-family:'Fraunces';font-weight:600;font-size:13px;line-height:1.4;max-width:340px}
  .cm-payback-seal svg{color:var(--lime);flex:0 0 18px}
  /* CREDIT-CARD style member card for Community Membership */
  .cm-cardwrap{display:flex;flex-direction:column;align-items:center;gap:14px}
