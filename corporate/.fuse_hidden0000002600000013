<script>
  const buttons = document.querySelectorAll('.toggle button');
  const amounts = document.querySelectorAll('.amount[data-monthly]');
  const perdayNums = document.querySelectorAll('.perday-num[data-monthly-text]');
  const annualNotes = document.querySelectorAll('.annual-note');
  const annualEqs = document.querySelectorAll('.annual-eq');
  const vsCosts = document.querySelectorAll('.vs-cost-val[data-monthly]');
  const vsSaveAmts = document.querySelectorAll('.vs-save-amt[data-monthly]');
  const vsPcts = document.querySelectorAll('.vs-pct[data-monthly]');
  const pwds = document.querySelectorAll('.pwd[data-monthly]');

  const altCadenceNotes = document.querySelectorAll('.alt-cadence-note[data-monthly]');
  function setCadence(cad){
    const isAnnual = cad === 'annual';
    buttons.forEach(x => {
      const match = x.dataset.cad === cad;
      x.classList.toggle('active', match);
      x.setAttribute('aria-selected', match ? 'true' : 'false');
    });
    amounts.forEach(a => { a.textContent = isAnnual ? a.dataset.annual : a.dataset.monthly; });
    perdayNums.forEach(p => { p.textContent = isAnnual ? p.dataset.annualText : p.dataset.monthlyText; });
    annualNotes.forEach(n => { n.classList.toggle('show', isAnnual); });
    annualEqs.forEach(e => { e.style.display = isAnnual ? 'inline' : 'none'; });
    vsCosts.forEach(v => { v.textContent = isAnnual ? v.dataset.annual : v.dataset.monthly; });
    vsSaveAmts.forEach(v => { v.textContent = isAnnual ? v.dataset.annual : v.dataset.monthly; });
    vsPcts.forEach(v => { v.textContent = isAnnual ? v.dataset.annual : v.dataset.monthly; });
    pwds.forEach(p => { p.textContent = isAnnual ? p.dataset.annual : p.dataset.monthly; });
    altCadenceNotes.forEach(n => {
      n.textContent = isAnnual ? n.dataset.annual : n.dataset.monthly;
      n.classList.add('show');
    });
  }

  buttons.forEach(b => { b.addEventListener('click', () => setCadence(b.dataset.cad)); });

  // Default to Annual on load
  setCadence('annual');
</script>

