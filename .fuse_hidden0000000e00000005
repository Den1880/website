<script>
  const buttons = document.querySelectorAll('.toggle button');
  const amounts = document.querySelectorAll('.amount[data-monthly]');
  const perdayNums = document.querySelectorAll('.perday-num[data-monthly-perday]');
  const annualNotes = document.querySelectorAll('.annual-note');
  const annualEqs = document.querySelectorAll('.annual-eq');

  buttons.forEach(b => {
    b.addEventListener('click', () => {
      buttons.forEach(x => { x.classList.remove('active'); x.setAttribute('aria-selected','false'); });
      b.classList.add('active');
      b.setAttribute('aria-selected','true');
      const cad = b.dataset.cad;
      const isAnnual = cad === 'annual';

      amounts.forEach(a => { a.textContent = isAnnual ? a.dataset.annual : a.dataset.monthly; });
      perdayNums.forEach(p => { p.textContent = isAnnual ? p.dataset.annualPerday : p.dataset.monthlyPerday; });
      annualNotes.forEach(n => { n.classList.toggle('show', isAnnual); });
      annualEqs.forEach(e => { e.style.display = isAnnual ? 'inline' : 'none'; });
    });
  });

  // Day pass toggle
  function switchDpPlan(plan) {
    document.querySelectorAll('.dp-tab').forEach(t => t.classList.toggle('active', t.dataset.plan === plan));
    document.getElementById('dp-monthly').classList.toggle('hidden', plan !== 'monthly');
    document.getElementById('dp-pack').classList.toggle('hidden', plan !== 'pack');
  }
  document.querySelectorAll('.dp-tab').forEach(tab => {
    tab.addEventListener('click', () => switchDpPlan(tab.dataset.plan));
  });

  // Hamburger menu
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', isOpen);
    mobileMenu.setAttribute('aria-hidden', !isOpen);
  });
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', false);
    });
  });
  document.addEventListener('click', e => {
    if (!hamburger.contains(e.target) && !mobileMenu.contains(e.target)) {
      mobileMenu.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', false);
    }
  });
</script>

