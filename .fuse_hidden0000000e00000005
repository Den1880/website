<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Den 1880 Pricing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  @font-face {
    font-family: 'Monschone';
    src: url('assets/fonts/Monschone.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
  :root{
    --ink:#0E0E0E;
    --ink-2:#2A2A2A;
    --paper:#F7F4EE;
    --card:#F7F4EE;
    --line:#E6E1D6;
    --muted:#6F6A60;
    --lime:#C8E020;
    --lime-deep:#9DB315;
    --plum:#6B4E8E;
    --gold:#B89252;
    --warn:#C0392B;
    --shadow:0 1px 2px rgba(14,14,14,.04), 0 8px 32px rgba(14,14,14,.06);
    --shadow-lift:0 2px 6px rgba(14,14,14,.06), 0 24px 60px rgba(14,14,14,.12);
    --radius:14px;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--paper);color:var(--ink);font-family:'Inter',system-ui,-apple-system,sans-serif;font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased}
  h1,h2,h3,h4{font-family:'Monschone','Fraunces',Georgia,serif;font-weight:600;letter-spacing:-0.01em;margin:0}
  h1{font-size:clamp(40px,6vw,72px);line-height:1.02;letter-spacing:-0.025em}
  h2{font-size:clamp(28px,3.4vw,42px);line-height:1.1}
  h3{font-size:clamp(20px,2vw,26px)}
  p{margin:0 0 .8em}
  a{color:inherit}
  .container{max-width:1280px;margin:0 auto;padding:0 24px}

  .topbar{display:flex;justify-content:space-between;align-items:center;padding:18px 24px;border-bottom:1px solid var(--line);background:var(--paper);position:sticky;top:0;z-index:50;backdrop-filter:blur(8px)}
  .logo{display:inline-flex;align-items:center}
  .nav-cta{display:flex;gap:10px;align-items:center}
  .btn{display:inline-flex;align-items:center;gap:8px;padding:12px 20px;border-radius:999px;font-weight:600;font-size:14px;text-decoration:none;border:1px solid transparent;transition:transform .15s ease, background .15s ease, box-shadow .15s ease;cursor:pointer}
  .btn-primary{background:var(--ink);color:#fff}
  .btn-primary:hover{background:var(--plum);transform:translateY(-1px)}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--ink)}
  .btn-ghost:hover{background:var(--ink);color:#fff}
  .btn-lime{background:var(--lime);color:var(--ink)}
  .btn-lime:hover{background:var(--lime-deep)}
  .btn-sm{padding:9px 16px;font-size:13px}

  /* ── HAMBURGER (mobile only) ── */
  .hamburger{display:none;flex-direction:column;justify-content:center;align-items:center;gap:5px;width:38px;height:38px;background:transparent;border:1px solid var(--line);border-radius:8px;cursor:pointer;padding:0;flex-shrink:0}
  .hamburger span{display:block;width:18px;height:2px;background:var(--ink);border-radius:2px;transition:all .25s ease}
  .hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .hamburger.open span:nth-child(2){opacity:0}
  .hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
  .mobile-menu{display:none;position:fixed;top:57px;left:0;right:0;z-index:99;background:rgba(247,244,238,0.98);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);padding:12px 24px 20px;flex-direction:column;gap:0;box-shadow:0 8px 24px rgba(14,14,14,0.08)}
  .mobile-menu.open{display:flex}
  .mobile-menu a{display:block;padding:14px 0;font-family:'Inter',sans-serif;font-size:15px;font-weight:500;color:var(--ink);text-decoration:none;border:none;border-bottom:1px solid var(--line);background:transparent;transition:color .15s ease}
  .mobile-menu a:last-of-type{border-bottom:none}
  .mobile-menu a:hover{color:var(--lime-deep)}
  .mobile-menu .mobile-cta{background:var(--lime);color:var(--ink);text-align:center;margin-top:12px;padding:14px;border-radius:999px;font-weight:700;border-bottom:none}
  .mobile-menu .mobile-cta:hover{background:var(--lime-deep)}
  @media(max-width:768px){
    .topbar{padding:14px 20px}
    .nav-cta{display:none}
    .hamburger{display:flex}
  }

  .hero{padding:72px 0 36px;text-align:center;position:relative;overflow:hidden}
  .hero .eyebrow{display:inline-block;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:18px}
  .hero h1 em{font-style:italic;color:var(--plum)}
  .hero p.lede{max-width:680px;margin:18px auto 0;color:var(--ink-2);font-size:18px}
  .hero-fineprint{margin-top:28px;color:var(--muted);font-size:13px}
  .hero-fineprint strong{color:var(--ink);font-weight:600}

  .toggle-wrap{display:flex;justify-content:center;align-items:center;gap:16px;margin:48px 0 12px}
  .toggle{display:inline-flex;background:#fff;border:1px solid var(--line);border-radius:999px;padding:4px;box-shadow:var(--shadow);position:relative}
  .toggle button{border:0;background:transparent;font-family:inherit;font-size:14px;font-weight:600;padding:10px 20px;border-radius:999px;cursor:pointer;color:var(--muted);transition:all .2s ease}
  .toggle button.active{background:var(--ink);color:#fff}
  .annual-pill{position:absolute;top:-28px;right:0;background:var(--lime);color:var(--ink);font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;padding:5px 11px;border-radius:999px;white-space:nowrap;box-shadow:0 3px 10px rgba(157,179,21,.4);border:1.5px solid var(--ink);animation:bobble 2.4s ease-in-out infinite;pointer-events:none}
  .annual-pill::after{content:'';position:absolute;bottom:-5px;right:28px;transform:rotate(45deg);width:8px;height:8px;background:var(--lime);border-right:1.5px solid var(--ink);border-bottom:1.5px solid var(--ink)}
  @keyframes bobble{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
  .save-tag{font-size:12px;color:var(--lime-deep);font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:rgba(200,224,32,.18);padding:6px 10px;border-radius:6px}

  /* PLAN GRID, 3 tier */
  .plans{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin:24px auto 12px;align-items:stretch;max-width:1080px}
  @media (max-width:900px){
    .plans{grid-template-columns:1fr;max-width:480px}
    .plan.featured{transform:none;margin-top:8px}
    .plan.featured:hover{transform:translateY(-3px)}
  }
  .plan{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:28px 22px 24px;display:flex;flex-direction:column;position:relative;transition:transform .2s ease, box-shadow .2s ease;box-shadow:var(--shadow)}
  .plan:hover{transform:translateY(-3px);box-shadow:var(--shadow-lift)}
  .plan .ribbon{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--ink);color:var(--lime);font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;padding:7px 14px;border-radius:999px;white-space:nowrap}
  .plan.featured{border-color:var(--ink);box-shadow:0 6px 12px rgba(14,14,14,.06), 0 36px 80px rgba(107,78,142,.18);transform:translateY(-8px) scale(1.04);z-index:2;background:linear-gradient(180deg,#fff 0%,#FBF9F3 100%)}
  .plan.featured:hover{transform:translateY(-11px) scale(1.04)}
  .plan .ptitle{font-family:'Fraunces';font-weight:600;font-size:24px;letter-spacing:-.01em;margin-bottom:4px}
  .plan .ptag{font-size:13px;color:var(--muted);min-height:38px;margin-bottom:18px}
  .plan .price{display:flex;align-items:baseline;gap:6px;margin-bottom:6px}
  .plan .price .currency{font-size:18px;color:var(--muted);font-weight:500}
  .plan .price .amount{font-family:'Fraunces';font-weight:800;font-size:54px;line-height:1;letter-spacing:-.02em}
  .plan .price .unit{font-size:13px;color:var(--muted);font-weight:500}
  .plan .reg-price{font-size:13px;color:var(--muted);margin-bottom:2px;display:flex;align-items:center;gap:8px}
  .plan .reg-price s{color:#B5AFA1;font-variant-numeric:tabular-nums}
  .plan .reg-price .limited{display:inline-block;background:var(--warn);color:#fff;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase}
  .plan .perday{display:inline-flex;align-items:baseline;gap:6px;background:rgba(200,224,32,.18);color:var(--ink);padding:6px 11px;border-radius:999px;font-size:12px;font-weight:600;margin:8px 0 6px;border:1px solid rgba(157,179,21,.35)}
  .plan .perday .perday-num{font-family:'Fraunces';font-size:15px;font-weight:700;color:var(--lime-deep)}
  .plan.featured .perday{background:var(--lime);border-color:var(--lime-deep)}
  .plan .annual-note{display:none;font-size:11px;color:var(--plum);font-weight:600;letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px}
  .plan .annual-note.show{display:block}
  .plan .price-sub{font-size:12px;color:var(--muted);margin-bottom:6px}
  .plan .anchor{font-size:12px;color:var(--muted);margin-bottom:16px}
  .plan .anchor s{color:#B5AFA1}
  .plan .anchor strong{color:var(--lime-deep)}
  .plan ul{list-style:none;margin:12px 0 20px;padding:0;flex:1}
  .plan li{display:flex;gap:9px;padding:6px 0;font-size:13px;color:var(--ink-2);align-items:flex-start;line-height:1.4}
  .plan li svg{flex:0 0 14px;margin-top:3px}
  .plan li.disabled{color:#B0AB9F}
  .plan li.disabled svg{color:#D4CFC1}
  .plan li.hero-feature{font-weight:600;color:var(--ink)}
  .plan .cta{margin-top:auto}
  .plan .cta a{width:100%;justify-content:center}
  .plan .micro{margin-top:10px;font-size:11px;color:var(--muted);text-align:center}
  .plan .guarantee-badge{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px;padding:7px 9px;background:rgba(200,224,32,.14);border:1px dashed var(--lime-deep);border-radius:8px;font-size:11px;font-weight:600;color:var(--ink);letter-spacing:.02em;text-align:center}
  .plan .guarantee-badge svg{color:var(--lime-deep);flex-shrink:0}
  /* MEMBERSHIPS: container around the 3-card plans grid */
  .memberships{max-width:1200px;margin:24px auto 0;background:transparent;border:1px solid var(--line);border-radius:var(--radius);padding:36px 32px 32px}
  .mb-header{text-align:center;margin-bottom:28px}
  .mb-header .mb-eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;display:inline-block}
  .mb-header h2{font-size:clamp(28px,3.4vw,38px);margin-bottom:8px;line-height:1.1}
  .mb-header p{font-size:14px;color:var(--ink-2);margin:0 auto;max-width:620px}
  .memberships .plans{padding-top:32px}


  /* DAY PASS, mini comparison chart with featured middle */
  .daypass{max-width:980px;margin:56px auto 0;background:transparent;border:1px solid var(--line);border-radius:var(--radius);padding:36px 32px 32px}
  .dp-header{text-align:center;margin-bottom:28px}
  .dp-header .dp-eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;display:inline-block}
  .dp-header h3{font-size:24px;margin-bottom:8px}
  .dp-header p{font-size:14px;color:var(--ink-2);margin:0 auto;max-width:620px}
  .dp-options{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;align-items:stretch;padding-top:8px;max-width:720px;margin:0 auto}
  @media (max-width:760px){.dp-options{grid-template-columns:1fr;gap:14px;max-width:420px}}
  .dp-monthly-note{background:rgba(200,224,32,.18);border:1px solid rgba(157,179,21,.4);border-radius:8px;padding:10px 12px;font-size:11px;color:var(--ink-2);margin:12px 0 0;line-height:1.4;text-align:center}
  .dp-monthly-note strong{color:var(--ink);font-family:'Fraunces';font-weight:700;font-size:14px;display:block;margin-bottom:2px}
  .dp-option .dp-cta{display:flex;flex-direction:column;gap:8px;margin-top:14px}
  .dp-option .dp-cta a{display:flex;width:100%;justify-content:center}
  .dp-option{border:1px solid var(--line);border-radius:10px;padding:20px 16px 18px;text-align:center;background:#FBF9F3;transition:all .2s ease;display:flex;flex-direction:column;position:relative}
  .dp-option:hover{border-color:var(--ink);background:#fff}
  .dp-option.featured{border:1.5px solid var(--ink);box-shadow:0 6px 12px rgba(14,14,14,.06), 0 36px 80px rgba(107,78,142,.18);transform:translateY(-8px) scale(1.04);z-index:2;background:linear-gradient(180deg,#fff 0%,#FBF9F3 100%);padding-top:26px}
  .dp-option.featured:hover{transform:translateY(-10px) scale(1.04)}
  .dp-option.featured .dp-price{font-family:'Fraunces';font-weight:700;font-size:38px;letter-spacing:-.02em;color:var(--ink);line-height:1}
  .dp-option.featured .dp-sub{font-size:13px;color:var(--muted);margin-top:6px;flex:none;min-height:auto}
  .dp-onetimelnk{display:block;text-align:center;font-size:12px;color:var(--muted);margin-top:10px;text-decoration:underline;text-underline-offset:3px;cursor:pointer}
  .dp-onetimelnk:hover{color:var(--ink)}
  .dp-ribbon{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--ink);color:var(--lime);font-size:9px;letter-spacing:.16em;text-transform:uppercase;font-weight:700;padding:5px 11px;border-radius:999px;white-space:nowrap}
  .dp-option .dp-label{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:10px}
  .dp-option .dp-price{font-family:'Fraunces';font-weight:700;font-size:30px;letter-spacing:-.02em;color:var(--ink);line-height:1;white-space:nowrap}
  .dp-option .dp-price small{font-size:12px;color:var(--muted);font-weight:500;font-family:'Inter'}
  .dp-option .dp-sub{font-size:12px;color:var(--muted);margin-top:6px;min-height:32px;flex:1}
  .dp-toggle{display:flex;gap:3px;background:rgba(14,14,14,.07);border-radius:999px;padding:3px;margin:10px auto 16px;width:fit-content}
  .dp-tab{background:transparent;border:none;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:6px 14px;border-radius:999px;cursor:pointer;color:var(--muted);font-family:'Inter',sans-serif;transition:all .2s ease}
  .dp-tab.active{background:var(--ink);color:var(--lime)}
  .dp-plan{display:flex;flex-direction:column;flex:1}
  .dp-plan.hidden{display:none}
  .addon-btn{display:inline-flex;align-items:center;justify-content:center;margin-top:16px;padding:9px 16px;border-radius:999px;font-weight:600;font-size:13px;text-decoration:none;border:1px solid var(--ink);color:var(--ink);background:transparent;transition:all .2s ease;width:100%}
  .addon-btn:hover{background:var(--ink);color:#fff}

  section{padding:72px 0}
  section h2{text-align:center;margin-bottom:8px}
  section .sub{text-align:center;color:var(--muted);max-width:640px;margin:0 auto 40px}

  .compare{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
  .compare table{width:100%;border-collapse:collapse;font-size:14px}
  .compare th, .compare td{padding:14px 14px;text-align:left;border-bottom:1px solid var(--line)}
  .compare th{background:#FBF9F3;font-weight:600;font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);position:sticky;top:0}
  .compare th.col, .compare td.col{text-align:center}
  .compare th.col-feat{background:var(--ink);color:var(--lime);text-align:center;position:relative}
  .compare td.col-feat{background:#FCFBF7;text-align:center}
  .compare td.row-section{background:var(--paper);font-family:'Fraunces';font-weight:600;font-size:15px;letter-spacing:-.005em;color:var(--ink);text-transform:none}
  .compare svg.tick{color:var(--lime-deep)}
  .compare svg.dash{color:#D6D1C4}
  .compare .lite{color:var(--muted);font-size:13px}
  .compare .cell-note{display:block;font-size:12px;color:var(--muted);margin-top:4px;line-height:1.3}
  .compare .multi-tick{display:inline-flex;gap:2px;align-items:center;justify-content:center}
  .compare tr:last-child td{border-bottom:0}

  .teams{background:var(--ink);color:#fff;border-radius:var(--radius);padding:48px 40px;display:grid;grid-template-columns:1.4fr 1fr;gap:40px;align-items:center;box-shadow:var(--shadow-lift)}
  @media (max-width:880px){.teams{grid-template-columns:1fr}}
  .teams h2{text-align:left;color:#fff}
  .teams .scarce{display:inline-block;background:rgba(200,224,32,.16);color:var(--lime);font-size:12px;letter-spacing:.12em;text-transform:uppercase;font-weight:700;padding:6px 12px;border-radius:6px;margin-bottom:18px}
  .teams p{color:#CDC8BC}
  .teams .team-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:24px}
  .teams .stat{background:rgba(255,255,255,.05);padding:18px;border-radius:10px}
  .teams .stat .num{font-family:'Fraunces';font-weight:600;font-size:28px;color:var(--lime)}
  .teams .stat .lbl{font-size:12px;color:#CDC8BC;letter-spacing:.04em;text-transform:uppercase;margin-top:6px}

  .addons{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  @media (max-width:900px){.addons{grid-template-columns:1fr}}
  .addon{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:24px;box-shadow:var(--shadow)}
  .addon .price{font-family:'Fraunces';font-weight:700;font-size:32px;letter-spacing:-.02em;margin:6px 0}
  .addon .price small{font-size:14px;color:var(--muted);font-weight:500;font-family:'Inter'}
  .addon h3{margin-bottom:6px}
  .addon p{color:var(--ink-2);font-size:14px}
  .addon .pill{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;padding:5px 10px;background:rgba(107,78,142,.1);color:var(--plum);border-radius:999px;margin-bottom:10px}

  .stack{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:36px;box-shadow:var(--shadow);max-width:760px;margin:0 auto}
  .stack-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px dashed var(--line);font-size:15px;color:var(--ink-2)}
  .stack-row:last-of-type{border-bottom:0}
  .stack-row .v{font-variant-numeric:tabular-nums;color:var(--ink)}
  .stack-total{display:flex;justify-content:space-between;align-items:baseline;margin-top:18px;padding-top:18px;border-top:2px solid var(--ink)}
  .stack-total .lbl{font-family:'Fraunces';font-size:18px;font-weight:600}
  .stack-total .v{font-family:'Fraunces';font-size:28px;font-weight:700;color:var(--ink);text-decoration:line-through;text-decoration-color:#C5C0B0}
  .stack-final{display:flex;justify-content:space-between;align-items:baseline;margin-top:14px;padding:14px 18px;background:var(--lime);border-radius:10px}
  .stack-final .lbl{font-family:'Fraunces';font-size:17px;font-weight:600;color:var(--ink)}
  .stack-final .v{font-family:'Fraunces';font-size:32px;font-weight:800;color:var(--ink)}
  .stack-disclaimer{margin-top:14px;font-size:12px;color:var(--muted);text-align:center}

  .guarantee{display:grid;grid-template-columns:auto 1fr;gap:28px;align-items:center;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:32px;box-shadow:var(--shadow)}
  @media (max-width:680px){.guarantee{grid-template-columns:1fr;text-align:center}}
  .guarantee .seal{width:96px;height:96px;border-radius:50%;background:var(--lime);display:flex;align-items:center;justify-content:center;font-family:'Fraunces';font-weight:800;font-size:13px;line-height:1.05;text-align:center;color:var(--ink);letter-spacing:.04em;text-transform:uppercase;border:3px solid var(--ink)}
  .guarantee h3{margin-bottom:6px}
  .guarantee p{color:var(--ink-2);font-size:15px;margin:0}

  .quotes{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  @media (max-width:900px){.quotes{grid-template-columns:1fr}}
  .quote{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:24px;box-shadow:var(--shadow);position:relative}
  .quote::before{content:'\201C';font-family:'Fraunces';font-size:64px;line-height:.6;color:var(--plum);position:absolute;top:18px;left:14px}
  .quote p{font-style:italic;color:var(--ink-2);margin:18px 0 16px;font-size:15px;padding-left:18px}
  .quote .who{font-size:13px;font-weight:600;padding-left:18px}
  .quote .who span{display:block;color:var(--muted);font-weight:400;font-size:12px;margin-top:2px}

  details{background:var(--paper);border:1px solid var(--line);border-radius:10px;padding:18px 20px;margin-bottom:10px;cursor:pointer}
  details[open]{box-shadow:var(--shadow)}
