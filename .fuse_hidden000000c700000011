  <meta name="description" content="Beautifully designed meeting rooms available on demand at Den 1880, Uptown Waterloo. Book by the hour or the day — members save 20%." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,600;1,500;1,600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #111111;
      --off-black: #1c1c1c;
      --mid: #666666;
      --light: #f4f2ef;
      --border: #e0ddd8;
      --lime: #c8f135;
      --white: #ffffff;
      --font-sans: 'Inter', system-ui, sans-serif;
      --font-serif: 'Playfair Display', Georgia, serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-sans);
      background: var(--white);
      color: var(--off-black);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    .nav-announcement {
      background: var(--black);
      color: var(--white);
      text-align: center;
      font-size: 0.78rem;
      padding: 0.55rem 1rem;
      letter-spacing: 0.01em;
    }
    .nav-announcement a { color: var(--lime); text-decoration: none; }

    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    .nav-logo img { height: 28px; display: block; }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.75rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--off-black);
      text-decoration: none;
      letter-spacing: 0.01em;
    }
    .nav-links a:hover { color: var(--mid); }
    .nav-links .btn-nav {
      background: var(--black);
      color: var(--white) !important;
      padding: 0.45rem 1.1rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .nav-links .btn-nav:hover { background: #333; color: var(--white) !important; }

    /* ── HERO ── */
    .hero {
      padding: 5rem 2rem 4rem;
      max-width: 900px;
      margin: 0 auto;
    }
    .hero-eyebrow {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 1.25rem;
    }
    .hero h1 {
      font-family: var(--font-serif);
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 600;
      line-height: 1.1;
      color: var(--black);
      margin-bottom: 1.5rem;
    }
    .hero h1 em { font-style: italic; font-weight: 500; }
    .hero-desc {
      font-size: 1.05rem;
      color: var(--mid);
      max-width: 560px;
      margin-bottom: 2rem;
      line-height: 1.7;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-block;
      background: var(--black);
      color: var(--white);
      padding: 0.75rem 1.6rem;
      border-radius: 4px;
      font-size: 0.88rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: background 0.15s;
    }
    .btn-primary:hover { background: #333; }
    .hero-note { font-size: 0.82rem; color: var(--mid); }
    .hero-note strong { color: var(--off-black); }

    /* ── DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--border); margin: 0 2rem; }

    /* ── MEMBER CALLOUT ── */
    .member-callout {
      background: var(--light);
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      font-size: 0.88rem;
      color: var(--off-black);
      text-align: center;
      flex-wrap: wrap;
    }
    .member-callout strong { font-weight: 600; }
    .member-callout a { color: var(--off-black); text-decoration: underline; text-underline-offset: 3px; }

    /* ── ROOMS SECTION ── */
    .rooms-section {
      max-width: 1120px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    /* ── ROOM CARD ── */
    .room-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 2rem;
    }
    .room-card.reverse { direction: rtl; }
    .room-card.reverse > * { direction: ltr; }
    .room-card.featured { grid-template-columns: 1.2fr 1fr; }

    .room-photo {
      position: relative;
      overflow: hidden;
      background: var(--light);
      min-height: 320px;
    }
    .room-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }
    .room-card:hover .room-photo img { transform: scale(1.03); }
    .room-photo-placeholder {
      width: 100%;
      height: 100%;
      min-height: 320px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      color: var(--mid);
      background: var(--light);
    }

    .room-body {
      padding: 2.5rem 2.75rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 1rem;
    }
    .room-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .tag {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.25rem 0.65rem;
      border-radius: 3px;
      background: var(--light);
      color: var(--mid);
    }
    .tag.members-only { background: var(--lime); color: var(--black); }

    .room-name {
      font-family: var(--font-serif);
      font-size: clamp(1.4rem, 2.5vw, 1.9rem);
      font-weight: 600;
      color: var(--black);
      line-height: 1.2;
    }
    .room-capacity {
      font-size: 0.82rem;
      color: var(--mid);
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .room-desc {
      font-size: 0.92rem;
      color: #444;
      line-height: 1.65;
    }
    .room-pricing {
      display: flex;
      gap: 1.5rem;
      padding: 1rem 0;
      border-top: 1px solid var(--border);
    }
    .price-item { display: flex; flex-direction: column; gap: 0.15rem; }
    .price-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--mid); font-weight: 500; }
    .price-value { font-size: 1.05rem; font-weight: 600; color: var(--black); }
    .room-cta {
      display: inline-block;
      background: var(--black);
      color: var(--white);
      padding: 0.7rem 1.4rem;
      border-radius: 4px;
      font-size: 0.84rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.01em;
      width: fit-content;
      transition: background 0.15s;
    }
    .room-cta:hover { background: #333; }
    .price-note {
      font-size: 0.78rem;
      color: var(--mid);
      line-height: 1.55;
      margin-top: 0.5rem;
    }

    /* ── EXTRAS SECTION ── */
    .extras-section {
      background: var(--light);
      padding: 4rem 2rem;
    }
    .extras-inner {
      max-width: 1120px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .extra-block h3 {
      font-family: var(--font-serif);
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--black);
      margin-bottom: 0.6rem;
    }
    .extra-block p {
      font-size: 0.9rem;
      color: var(--mid);
      line-height: 1.65;
      margin-bottom: 1rem;
    }
    .extra-block a.btn-primary { font-size: 0.82rem; padding: 0.6rem 1.2rem; }

    /* ── FOOTER CTA ── */
    .footer-cta {
      padding: 4rem 2rem;
      text-align: center;
      max-width: 640px;
      margin: 0 auto;
    }
    .footer-cta h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 600;
      color: var(--black);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }
    .footer-cta h2 em { font-style: italic; font-weight: 500; }
    .footer-cta p { font-size: 0.95rem; color: var(--mid); margin-bottom: 2rem; line-height: 1.7; }
    .footer-cta .actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn-outline {
      display: inline-block;
      border: 1px solid var(--border);
      color: var(--off-black);
      padding: 0.7rem 1.4rem;
      border-radius: 4px;
      font-size: 0.84rem;
      font-weight: 500;
      text-decoration: none;
      transition: border-color 0.15s;
    }
    .btn-outline:hover { border-color: var(--off-black); }

    /* ── SITE FOOTER ── */
    footer {
      background: var(--black);
      color: #aaa;
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
    }
    footer a { color: #aaa; text-decoration: none; }
    footer a:hover { color: var(--white); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav { padding: 0 1rem; }
      .nav-links { display: none; }
      .hero { padding: 3rem 1.25rem 2.5rem; }
      .rooms-section { padding: 3rem 1.25rem; }
      .room-card,
      .room-card.reverse,
      .room-card.featured { grid-template-columns: 1fr; direction: ltr; }
      .room-card.reverse .room-photo { order: -1; }
      .room-body { padding: 1.75rem; }
      .extras-inner { grid-template-columns: 1fr; }
      .extras-section { padding: 3rem 1.25rem; }
    }
  </style>
</head>
